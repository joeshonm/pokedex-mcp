# Copy this file to .env and fill in the values for your environment.
# Real environment variables override anything set in .env.

# --- MCP resource server ---
HOST=localhost
PORT=3000

# --- Keycloak authorization server ---
AUTH_HOST=localhost
AUTH_PORT=8080
AUTH_REALM=master

# --- OAuth client credentials ---
# NOTE: The current token verifier validates JWTs locally against the realm
# JWKS and does NOT use these. They are only needed if you switch the verifier
# back to RFC 7662 introspection. Clients (e.g. Claude Code) register their own
# client via Dynamic Client Registration regardless of what is set here.
OAUTH_CLIENT_ID=pokedex-client
OAUTH_CLIENT_SECRET=

# --- MCP settings ---
MCP_SCOPE=mcp:tools
OAUTH_STRICT=false
TRANSPORT=streamable-http
